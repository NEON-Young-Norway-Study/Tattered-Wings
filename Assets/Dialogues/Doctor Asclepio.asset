    width: 190
    height: 135
  isDragging: 0
  isSelected: 0
  sentence:
    characterName: Dr. Asclepio
    text: "You inhale through your nose for 4 seconds, hold for 7, and then slowly
      exhale through your mouth for 8 seconds. It\u2019s like a reset."
    characterSprite: {fileID: 393688136, guid: 542f93bf2d7349c4cbf7c470be2eec28, type: 3}
