    width: 190
    height: 135
  isDragging: 0
  isSelected: 0
  sentence:
    characterName: Dr. Asclepio
    text: Social anxiety is complex, and it often takes more than just relaxation
      exercises to feel better. But there are some things that we can do, TJ, to
      help make things easier for you.
    characterSprite: {fileID: 752911950, guid: 39ca1e18178ad344ab405782c2a0ce5f, type: 3}
    secondSprite: {fileID: 1110156138, guid: 62a5601e016fc3e4b98b2a8a9b82412b, type: 3}
