    width: 190
    height: 135
  isDragging: 0
  isSelected: 0
  sentence:
    characterName: Dr. Asclepio
    text: "We call that social anxiety. It\u2019s when certain situations, especially
      around people, make your body react as if there\u2019s danger, even when there\u2019s
      none."
    characterSprite: {fileID: 1054310150, guid: 8fba30c7d3ecbd849abe05443485adb1,
      type: 3}
